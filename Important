// ── COUNTDOWN ─────────────────────────────────
function startCountdown(){ updateCountdown(); setInterval(updateCountdown,1000); }
function updateCountdown(){
  const times=getPrayerArray(); if(!times)return;
  const{next,current}=getCurrentAndNext(times);
  const L=LANGS[state.lang];
  const now=new Date();
  const nowSec=now.getHours()*3600+now.getMinutes()*60+now.getSeconds();
  let nextSec=timeToMin(times[next])*60;
  let prevSec=current>=0?timeToMin(times[current])*60:0;
  if(nextSec<=nowSec)nextSec+=86400;
  let diff=nextSec-nowSec;
  const h=Math.floor(diff/3600),m=Math.floor((diff%3600)/60),s=diff%60;
  document.getElementById('countdown').textContent=`${h.toString().padStart(2,'0')}:${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`;
  document.getElementById('nextPrayerName').textContent=L.prayers[next];
  document.getElementById('countdownLabel').textContent=L.next;
  const total=nextSec-prevSec, elapsed=nowSec-prevSec;
  document.getElementById('progressBar').style.width=Math.max(0,Math.min(100,(elapsed/total)*100))+'%';
}

