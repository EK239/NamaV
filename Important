  const ds=`${d.getDate().toString().padStart(2,'0')}-${(d.getMonth()+1).toString().padStart(2,'0')}-${d.getFullYear()}`;
  const url=`https://api.aladhan.com/v1/timings/${ds}?latitude=${state.lat}&longitude=${state.lng}&method=${state.method}&school=${state.asr}`;
  try{
    const r=await fetch(url);
    const data=await r.json();
    if(data.code===200){ state.prayerTimes=data.data; try{localStorage.setItem('cachedPT',JSON.stringify({data:data.data,date:ds}));}catch(e){} return data.data; }
  }catch(e){
    try{ const c=localStorage.getItem('cachedPT'); if(c){state.prayerTimes=JSON.parse(c).data; showToast('📶 Offline – gespeicherte Zeiten');} }catch(e2){}
  }
  return state.prayerTimes;
}

// ── RENDER HOME ───────────────────────────────
function getPrayerArray(){
  if(!state.prayerTimes) return null;
  const t=state.prayerTimes.timings;
  return [t.Fajr,t.Sunrise,t.Dhuhr,t.Asr,t.Maghrib,t.Isha].map(x=>x?.replace(/ \(.*\)/,'').trim());
}
function timeToMin(ts){ if(!ts)return 0; const[h,m]=ts.split(':').map(Number); return h*60+m; }
function getCurrentAndNext(times){
  const now=new Date();
  const nowMin=now.getHours()*60+now.getMinutes();
  let cur=-1,nxt=-1;
  for(let i=0;i<times.length;i++) if(timeToMin(times[i])<=nowMin) cur=i;
  if(cur===1)cur=0;
  nxt=cur+1; if(nxt>=times.length)nxt=0;
  return{current:cur,next:nxt};
}
function renderHome(){
  const L=LANGS[state.lang];
  const times=getPrayerArray();
  if(!times){document.getElementById('prayersList').innerHTML='<div style="padding:20px;color:var(--text-muted)">Lade...</div>';return;}
  const now=new Date();
  const opts={weekday:'long',year:'numeric',month:'long',day:'numeric'};
  document.getElementById('gregorianDate').textContent=now.toLocaleDateString(state.lang==='tr'?'tr-TR':state.lang==='en'?'en-US':'de-DE',opts);
  if(state.prayerTimes?.date?.hijri){
    const h=state.prayerTimes.date.hijri;
    document.getElementById('hijriDate').textContent=`${h.day} ${h.month.en}`;
    document.getElementById('hijriMonth').textContent=`${h.year} H`;
