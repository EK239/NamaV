// ── QIBLA ─────────────────────────────────────
function calcQibla(lat,lng){
  const kLat=21.4225*Math.PI/180,kLng=39.8262*Math.PI/180;
  const mLat=lat*Math.PI/180,mLng=lng*Math.PI/180,dL=kLng-mLng;
  const x=Math.sin(dL),y=Math.cos(mLat)*Math.tan(kLat)-Math.sin(mLat)*Math.cos(dL);
  return(Math.atan2(x,y)*180/Math.PI+360)%360;
}
function calcDist(a,b,c,d){
  const R=6371,dA=(c-a)*Math.PI/180,dB=(d-b)*Math.PI/180;
  const x=Math.sin(dA/2)**2+Math.cos(a*Math.PI/180)*Math.cos(c*Math.PI/180)*Math.sin(dB/2)**2;
  return Math.round(R*2*Math.atan2(Math.sqrt(x),Math.sqrt(1-x)));
}
function drawCompass(){
  const canvas=document.getElementById('compassCanvas');if(!canvas)return;
  const ctx=canvas.getContext('2d'),cx=140,cy=140,r=120;
  ctx.clearRect(0,0,280,280);
  for(let i=0;i<360;i+=5){
    const ang=(i-90)*Math.PI/180,maj=i%30===0,r1=r-(maj?14:8);
    ctx.beginPath();ctx.moveTo(cx+r1*Math.cos(ang),cy+r1*Math.sin(ang));ctx.lineTo(cx+r*Math.cos(ang),cy+r*Math.sin(ang));
    ctx.strokeStyle=maj?'rgba(201,168,76,0.6)':'rgba(201,168,76,0.2)';ctx.lineWidth=maj?1.5:0.8;ctx.stroke();
  }
}
function startQibla(){
  state.qiblaAngle=calcQibla(state.lat,state.lng);
  const dist=calcDist(state.lat,state.lng,21.4225,39.8262);
  document.getElementById('qiblaAngle').textContent=Math.round(state.qiblaAngle)+'°';
  document.getElementById('qiblaDistance').textContent=dist.toLocaleString()+' km';
  drawCompass();
  if(typeof DeviceOrientationEvent!=='undefined'&&typeof DeviceOrientationEvent.requestPermission==='function'){
    DeviceOrientationEvent.requestPermission().then(p=>{if(p==='granted')listenCompass();else showToast('Sensorzugriff verweigert');}).catch(()=>showToast('Fehler'));
  } else if(window.DeviceOrientationEvent){ listenCompass(); }
  else{ document.getElementById('sensorStatus').textContent='⚠️ Kein Kompass-Sensor'; updateQiblaArrow(0); }
}
function listenCompass(){
  document.getElementById('sensorStatus').className='sensor-status sensor-active';
  document.getElementById('sensorStatus').textContent='✅ Kompass aktiv';
  window.addEventListener('deviceorientationabsolute',handleOri,true);
  window.addEventListener('deviceorientation',handleOri,true);
}
function handleOri(e){
  let h=0;
  if(e.webkitCompassHeading!==undefined)h=e.webkitCompassHeading;
  else if(e.alpha!==null)h=360-e.alpha;
  document.getElementById('compassHeading').textContent=Math.round(h)+'°';
  updateQiblaArrow(h);
  const n=document.getElementById('compassNeedle');
  if(n)n.style.transform=`translateX(-50%) rotate(${-h}deg)`;
}
function updateQiblaArrow(h){
  const a=document.getElementById('qiblaArrow');if(!a)return;
  a.style.transform=`rotate(${state.qiblaAngle-h}deg)`;a.style.transformOrigin='140px 140px';
}

// ── NOTIFICATIONS ─────────────────────────────
async function reqNotif(){ if(!('Notification' in window))return false; if(Notification.permission==='granted')return true; return(await Notification.requestPermission())==='granted'; }
function toggleNotif(i){
  const was=state.notifications[i]; state.notifications[i]=!was;
  if(!was){ reqNotif().then(g=>{ if(!g){state.notifications[i]=false;showToast('❌ Benachrichtigungen blockiert');}else{scheduleNotif(i);showToast('🔔 Aktiviert');} saveState();renderHome(); }); }
  else{ showToast('🔕 Deaktiviert');saveState();renderHome(); }
}
function scheduleNotif(i){
  const times=getPrayerArray();if(!times||!times[i])return;
  const L=LANGS[state.lang];const[h,m]=times[i].split(':').map(Number);
  const now=new Date(),target=new Date();target.setHours(h,m,0,0);
  if(target<=now)target.setDate(target.getDate()+1);
  setTimeout(()=>{ if(state.notifications[i]&&Notification.permission==='granted'){new Notification(`🕌 ${L.prayers[i]}`,{body:`Gebetszeit: ${times[i]}`,vibrate:[200,100,200]});scheduleNotif(i);} },target-now);
}
function toggleAllNotif(){
  const allOn=Object.values(state.notifications).every(v=>v);
  reqNotif().then(g=>{
    if(g||allOn){ for(let i=0;i<6;i++){state.notifications[i]=!allOn;if(!allOn)scheduleNotif(i);}
      document.getElementById('allNotifToggle').className='toggle '+(!allOn?'on':'');
      saveState();renderHome();showToast(!allOn?'🔔 Alle aktiviert':'🔕 Alle deaktiviert'); }
    else showToast('❌ Benachrichtigungen blockiert');
  });
}

