        ${isA?'<span class="prayer-badge badge-active">AKTIV</span>':''}
        ${isN?'<span class="prayer-badge badge-next">NÄCHST</span>':''}
        <div class="prayer-time">${time}</div>
        <button class="notif-btn ${notifOn?'on':''}" onclick="toggleNotif(${i})">${notifOn?'🔔':'🔕'}</button>
