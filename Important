function openCityModal(){ document.getElementById('cityModal').classList.remove('hidden');renderCityList(CITIES);document.getElementById('citySearch').value=''; }
function closeCityModal(){ document.getElementById('cityModal').classList.add('hidden'); }
function renderCityList(cities){ document.getElementById('cityList').innerHTML=cities.map(c=>`<div class="city-item" onclick="selectCity('${c.name}',${c.lat},${c.lng})">${c.name}</div>`).join(''); }
function filterCities(q){ renderCityList(CITIES.filter(c=>c.name.toLowerCase().includes(q.toLowerCase()))); }
function selectCity(name,lat,lng){ state.city=name;state.lat=lat;state.lng=lng;saveState();closeCityModal();fetchPrayerTimes().then(()=>{renderHome();showToast(`📍 ${name} ausgewählt`);});}
document.getElementById('cityModal').addEventListener('click',function(e){if(e.target===this)closeCityModal();});

// ── TOAST ─────────────────────────────────────
let toastT;
function showToast(msg){ const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');clearTimeout(toastT);toastT=setTimeout(()=>t.classList.remove('show'),2500); }
</script>
